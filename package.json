{
  "name": "pageindex-vectorless",
  "version": "1.0.1",
  "description": "PageIndex - Vectorless RAG using LLM-based tree search",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "pageindex-vectorless": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "rag",
    "llm",
    "pageindex",
    "document-search",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sparrowwelcomehr-jpg/pageindex-ts.git"
  },
  "bugs": {
    "url": "https://github.com/sparrowwelcomehr-jpg/pageindex-ts/issues"
  },
  "homepage": "https://github.com/sparrowwelcomehr-jpg/pageindex-ts#readme",
  "dependencies": {
    "express": "^4.18.2",
    "openai": "^4.20.0",
    "pdf-parse": "^1.1.1",
    "cheerio": "^1.0.0-rc.12",
    "marked": "^11.0.0",
    "axios": "^1.6.2",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1"
  }
}
